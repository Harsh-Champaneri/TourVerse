# =============================================================================
# IBM watsonx.ai Configuration
# =============================================================================
# Get your API key from: https://cloud.ibm.com/iam/apikeys
WATSONX_API_KEY=

# Get your Project ID from: https://dataplatform.cloud.ibm.com/projects
WATSONX_PROJECT_ID=

# watsonx.ai API URL (change region if needed: us-south, eu-de, jp-tok, au-syd)
WATSONX_URL=

# IBM IAM Token URL (do not change)
IBM_IAM_URL=

# =============================================================================
# Granite Model Configuration
# =============================================================================
# Available models: ibm/granite-3-3-8b-instruct, ibm/granite-3-8b-instruct
# ibm/granite-13b-chat-v2, ibm/granite-20b-multilingual
WATSONX_MODEL_ID=

# =============================================================================
# OpenWeather API Configuration
# =============================================================================
# Get your free API key from: https://openweathermap.org/api
OPENWEATHER_API_KEY=

# =============================================================================
# Email Configuration (PHPMailer / SMTP)
# =============================================================================
# SMTP Host (e.g., smtp.gmail.com, smtp.outlook.com)
SMTP_HOST=smtp.gmail.com

# SMTP Port (587 for TLS, 465 for SSL, 25 for plain)
SMTP_PORT=587

# SMTP Username (your email address)
SMTP_USERNAME=

# SMTP Password (use App Password for Gmail)
# For Gmail: https://myaccount.google.com/apppasswords
SMTP_PASSWORD=

# Sender name and email
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=

# =============================================================================
# Application Configuration
# =============================================================================
# App name displayed in the UI
APP_NAME=

# App URL (no trailing slash) — used for PDF and email links
APP_URL=

# Environment: development | production
APP_ENV=

# Debug mode: true | false (set to false in production)
APP_DEBUG=true
